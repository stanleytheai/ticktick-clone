rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ──────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function isValidPriority() {
      return request.resource.data.priority in [0, 1, 2, 3];
    }

    // ── Shared Lists helpers ──────────────────────────
    function isSharedListMember(listData) {
      return isAuthenticated()
        && request.auth.uid in listData.members
        && listData.members[request.auth.uid].role in ['view', 'edit', 'admin'];
    }

    function hasSharedListRole(listData, minRole) {
      return isAuthenticated()
        && request.auth.uid in listData.members
        && (
          listData.members[request.auth.uid].role == minRole
          || listData.members[request.auth.uid].role == 'admin'
          || (minRole == 'view' && listData.members[request.auth.uid].role == 'edit')
        );
    }

    // ── Users ─────────────────────────────────────────
    // Only the authenticated owner can read/write their own user doc
    match /users/{uid} {
      allow read, write: if isOwner(uid);

      // ── Lists (subcollection) ─────────────────────
      match /lists/{listId} {
        allow read: if isOwner(uid);
        allow create: if isOwner(uid)
          && hasRequiredFields(['name', 'createdAt']);
        allow update: if isOwner(uid);
        allow delete: if isOwner(uid);
      }

      // ── Tasks (subcollection) ─────────────────────
      match /tasks/{taskId} {
        allow read: if isOwner(uid);
        allow create: if isOwner(uid)
          && hasRequiredFields(['title', 'listId', 'createdAt', 'completed'])
          && request.resource.data.title is string
          && request.resource.data.title.size() > 0
          && request.resource.data.completed is bool;
        allow update: if isOwner(uid)
          && request.resource.data.title is string
          && request.resource.data.title.size() > 0;
        allow delete: if isOwner(uid);

        // ── Subtasks ────────────────────────────────
        match /subtasks/{subtaskId} {
          allow read, write: if isOwner(uid);
        }

        // ── Comments ────────────────────────────────
        match /comments/{commentId} {
          allow read: if isOwner(uid);
          allow create: if isAuthenticated()
            && hasRequiredFields(['text', 'authorId', 'createdAt']);
          allow update, delete: if isAuthenticated()
            && resource.data.authorId == request.auth.uid;
        }
      }

      // ── Settings (subcollection) ─────────────────
      match /settings/{settingId} {
        allow read, write: if isOwner(uid);
      }

      // ── Tags (subcollection) ──────────────────────
      match /tags/{tagId} {
        allow read, write: if isOwner(uid);
      }

      // ── Habits (subcollection) ────────────────────
      match /habits/{habitId} {
        allow read, write: if isOwner(uid);

        match /logs/{logId} {
          allow read, write: if isOwner(uid);
        }
      }

      // ── Notes (subcollection) ──────────────────────
      match /notes/{noteId} {
        allow read: if isOwner(uid);
        allow create: if isOwner(uid)
          && hasRequiredFields(['title', 'createdAt']);
        allow update: if isOwner(uid);
        allow delete: if isOwner(uid);
      }

      // ── Note Folders (subcollection) ────────────────
      match /noteFolders/{folderId} {
        allow read: if isOwner(uid);
        allow create: if isOwner(uid)
          && hasRequiredFields(['name', 'createdAt']);
        allow update: if isOwner(uid);
        allow delete: if isOwner(uid);
      }

      // ── Pomodoro Sessions (subcollection) ─────────
      match /pomodoroSessions/{sessionId} {
        allow read, write: if isOwner(uid);
      }

      // ── Filters (subcollection) ───────────────────
      match /filters/{filterId} {
        allow read, write: if isOwner(uid);
      }
    }

    // ── Shared Lists ────────────────────────────────────
    match /sharedLists/{listId} {
      // Members can read the list
      allow read: if isSharedListMember(resource.data);

      // Any authenticated user can create (they become owner)
      allow create: if isAuthenticated()
        && hasRequiredFields(['name', 'ownerId', 'members', 'createdAt'])
        && request.resource.data.ownerId == request.auth.uid
        && request.auth.uid in request.resource.data.members;

      // Edit or admin can update
      allow update: if hasSharedListRole(resource.data, 'edit');

      // Only owner can delete
      allow delete: if isAuthenticated()
        && resource.data.ownerId == request.auth.uid;

      // ── Shared Tasks ────────────────────────────────
      match /tasks/{taskId} {
        allow read: if isSharedListMember(
          get(/databases/$(database)/documents/sharedLists/$(listId)).data
        );

        allow create: if hasSharedListRole(
          get(/databases/$(database)/documents/sharedLists/$(listId)).data,
          'edit'
        ) && hasRequiredFields(['title', 'createdAt', 'completed']);

        allow update: if hasSharedListRole(
          get(/databases/$(database)/documents/sharedLists/$(listId)).data,
          'edit'
        );

        allow delete: if hasSharedListRole(
          get(/databases/$(database)/documents/sharedLists/$(listId)).data,
          'edit'
        );

        // ── Task Comments ───────────────────────────
        match /comments/{commentId} {
          allow read: if isSharedListMember(
            get(/databases/$(database)/documents/sharedLists/$(listId)).data
          );

          allow create: if isSharedListMember(
            get(/databases/$(database)/documents/sharedLists/$(listId)).data
          ) && hasRequiredFields(['text', 'authorId', 'createdAt'])
            && request.resource.data.authorId == request.auth.uid;

          allow update: if isAuthenticated()
            && resource.data.authorId == request.auth.uid;

          allow delete: if isAuthenticated()
            && (resource.data.authorId == request.auth.uid
              || hasSharedListRole(
                get(/databases/$(database)/documents/sharedLists/$(listId)).data,
                'admin'
              ));
        }
      }

      // ── Activity Feed ─────────────────────────────
      match /activity/{activityId} {
        allow read: if isSharedListMember(
          get(/databases/$(database)/documents/sharedLists/$(listId)).data
        );

        // Only server (admin SDK) writes activity, but allow members to create
        allow create: if isSharedListMember(
          get(/databases/$(database)/documents/sharedLists/$(listId)).data
        );
      }
    }
  }
}
